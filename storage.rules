rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/user_roles/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/user_roles/$(request.auth.uid)).data.role == "admin" &&
        firestore.get(/databases/(default)/documents/user_roles/$(request.auth.uid)).data.enabled == true;
    }

    match /campaigns/{campaignId}/evidence/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        request.resource != null &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }
  }
}
