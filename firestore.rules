rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == "admin" &&
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.enabled == true;
    }

    match /settings/activeCampaign {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;

      match /donations/{donationId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      match /piggy_banks/{piggyBankId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      match /donor_totals/{donorId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      match /totals/{documentId} {
        allow read: if true;
        allow create, update: if isAdmin();
        allow delete: if false;
      }

      match /evidence/{evidenceId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /user_roles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /donations/{documentId} {
      allow read, write: if false;
    }

    match /stats/{documentId} {
      allow read, write: if false;
    }

    match /donor_totals/{documentId} {
      allow read, write: if false;
    }

    match /campaign_sync/{documentId} {
      allow read, write: if false;
    }

    match /admin_access_logs/{documentId} {
      allow read, write: if false;
    }
  }
}
